  "contentHtml": "<table id=\"bodyTable\">\n                <tbody><tr>\n                    <td id=\"bodyCell\">\n                        <!-- BEGIN TEMPLATE // -->\n                        <table>\n                            <tbody><tr>\n                                <td id=\"templateHeader\">\n                                    <!--[if (gte mso 9)|(IE)]>\n                                    <table align=\"center\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" width=\"600\" style=\"width:600px;\">\n                                    <tr>\n                                    <td align=\"center\" valign=\"top\" width=\"600\" style=\"width:600px;\">\n                                    <![endif]-->\n                                    <table>\n                                        <tbody><tr>\n                                            <td><table>\n    <tbody>\n        <tr>\n            <td>\n\n\n<table>\n    <tbody><tr>\n        <td>\n\n\n            <a href=\"https://arlbrew.us16.list-manage.com/track/click?u=be20bbfba341582993786f7f0&amp;id=e7213ea10b&amp;e=01c6cdb4b7\" target=\"_blank\" rel=\"noopener noreferrer\">\n\n\n            <img src=\"https://mcusercontent.com/be20bbfba341582993786f7f0/images/5480a828-def9-46fc-035d-c65cacb1a81b.png\" width=\"564\" loading=\"lazy\" decoding=\"async\">\n            </a>\n\n        </td>\n    </tr>\n    <tr>\n        <td>\n            <span><strong>Wine Fest on a weeknight?! Why,&nbsp;yes!&nbsp;</strong><strong>Join us for The Brew Shop's Annual Spring Wine Festival on Thursday, May 14 from 5:30 - 8:30 pm!</strong><br>\n<br>\n- Walk-about tasting featuring <strong>20 different Spring-forward&nbsp;wines</strong><br>\n- <strong>Outdoors and indoors! </strong>Enjoy the Spring weather with outdoor tasting stations along our front sidewalk<br>\n- Featuring artisanal&nbsp;<strong>cheese and crackers</strong><br>\n- <strong>Discounts </strong>for retail purchases on all&nbsp;wines<br>\n- Chat, learn and sip&nbsp;wine&nbsp;with our wonderful team of<strong> in-the-know&nbsp;wine&nbsp;distributors</strong><br>\n- A great way to stock up for Spring outings, family gatherings&nbsp;and patio time<br>\n<br>\nTo give us a little more space, the tasting has been split into two sessions: 5:30-7 pm and 7-8:30&nbsp;pm.&nbsp; Tickets are $20 per person ($15 for Wine Club Members). Please choose the time slot that&nbsp;works best for you!</span>\n\n        </td>\n    </tr>\n</tbody></table>\n\n\n\n\n\n            </td>\n        </tr>\n    </tbody>\n</table><table>\n    <tbody>\n        <tr>\n            <td>\n                <table>\n                    <tbody>\n                        <tr>\n                            <td>\n                                <a href=\"https://arlbrew.us16.list-manage.com/track/click?u=be20bbfba341582993786f7f0&amp;id=d5d6330ebd&amp;e=01c6cdb4b7\" target=\"_blank\" rel=\"noopener noreferrer\">Spring Wine Festival Tickets (5:30-7 pm)</a>\n                            </td>\n                        </tr>\n                    </tbody>\n                </table>\n            </td>\n        </tr>\n    </tbody>\n</table><table>\n    <tbody>\n        <tr>\n            <td>\n                <table>\n                    <tbody>\n                        <tr>\n                            <td>\n                                <a href=\"https://arlbrew.us16.list-manage.com/track/click?u=be20bbfba341582993786f7f0&amp;id=520ef018f8&amp;e=01c6cdb4b7\" target=\"_blank\" rel=\"noopener noreferrer\">Spring Wine Festival Tickets (7-8:30 pm)</a>\n                            </td>\n                        </tr>\n                    </tbody>\n                </table>\n            </td>\n        </tr>\n    </tbody>\n</table><table>\n    <tbody>\n        <tr>\n            <td>\n              \t<!--[if mso]>\n\t\t\t\t<table align=\"left\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" width=\"100%\" style=\"width:100%;\">\n\t\t\t\t<tr>\n\t\t\t\t<![endif]-->\n\t\t\t\n\t\t\t\t<!--[if mso]>\